# Cursor Usage 代理服务器配置
#
# 获取方法:
# 1. 浏览器打开 https://cursor.com/cn/dashboard/usage
# 2. 按 F12 打开开发者工具 -> Network 面板
# 3. 刷新页面，找到 usage 相关的 API 请求
# 4. 在请求头中找到 Cookie 值，复制整个 Cookie 字符串
#
# 或者使用 Cursor API Key (Business/Enterprise):
# 1. 打开 cursor.com/dashboard -> Settings -> Advanced -> Admin API Keys
# 2. 生成一个 API Key

# 方式1: 使用 Cookie（推荐，最简单）
CURSOR_COOKIE="你的完整Cookie字符串"

# 方式2: 使用 API Key（Business/Enterprise 用户）
# CURSOR_API_KEY="你的API Key"
# CURSOR_TEAM_ID="你的Team ID"

# 服务器配置
SERVER_PORT=8765
